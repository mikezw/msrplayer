<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MsrPlayer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="550"
        x:Class="MsrPlayer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Monster Siren Player"
        Width="1000" Height="550"
        MinWidth="800" MinHeight="400"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="4*, 3*, 3*" Margin="0">
        <!-- 第一列：歌曲列表 -->
        <Border Background="#121212">
            <DockPanel Margin="16,16">
                <!-- 标题区 -->
                <StackPanel DockPanel.Dock="Top" Spacing="6">
                    <TextBlock Text="歌曲列表" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="双击添加到播放列表" Foreground="#a0a0a0" FontSize="12"/>
                </StackPanel>

                <!-- 状态 -->
                <Border DockPanel.Dock="Top"
                        Background="#1e1e1e"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,10,0,10">
                    <TextBlock Text="{Binding StatusText}" Foreground="#1DB954" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- 歌曲列表 -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Songs}" x:Name="SongsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6"
                                        Background="Transparent"
                                        DoubleTapped="OnSongDoubleTapped"
                                        CornerRadius="4">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="#1a1a1a"/>
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="Auto, *" VerticalAlignment="Center">
                                        <!-- 添加按钮 -->
                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                Background="#1DB954"
                                                CornerRadius="14"
                                                Margin="0,0,10,0"
                                                Tapped="OnAddButtonTapped"
                                                Cursor="Hand">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="#22e05b"/>
                                                </Style>
                                            </Border.Styles>
                                            <TextBlock Text="+"
                                                       Foreground="Black"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 歌曲信息 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#e0e0e0"
                                                       FontWeight="Medium"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding ArtistDisplay}"
                                                       Foreground="#808080"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 第二列：播放控制区 -->
        <DockPanel Margin="16,16" Grid.Column="1" Background="#0a0a0a">
            <!-- 当前播放信息 -->
            <Border DockPanel.Dock="Top"
                    Background="#1e1e1e"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="正在播放"
                               FontSize="11"
                               Foreground="#808080"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentSongName}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1DB954"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="220"/>
                </StackPanel>
            </Border>

            <!-- 控制区域 -->
            <Border DockPanel.Dock="Top"
                    Background="#1e1e1e"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel Spacing="10">
                    <!-- 播放进度 -->
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CurrentTimeText}" FontSize="11" Foreground="#909090" VerticalAlignment="Center" Width="36"/>
                        <Slider Grid.Column="1"
                                Minimum="0" Maximum="100"
                                Value="{Binding CurrentPosition, Mode=TwoWay}"
                                Margin="6,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TotalTimeText}" FontSize="11" Foreground="#909090" VerticalAlignment="Center" Width="36"/>
                    </Grid>

                    <!-- 播放控制按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                        <Button Command="{Binding PrevCommand}" Classes="ctrlBtn" Width="40" Height="40" CornerRadius="20"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock Text="◀◀" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding TogglePlayCommand}" Classes="playBtn" Width="50" Height="50" CornerRadius="25"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
                                <TextBlock Text="▶" FontSize="18" FontWeight="Bold" IsVisible="{Binding !IsPlaying}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                <TextBlock Text="❚❚" FontSize="16" FontWeight="Bold" IsVisible="{Binding IsPlaying}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Command="{Binding NextCommand}" Classes="ctrlBtn" Width="40" Height="40" CornerRadius="20"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock Text="▶▶" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <!-- 播放模式 + 音量 -->
                    <Grid RowDefinitions="Auto, Auto, Auto" Margin="0,6">
                        <!-- 播放模式 + 缓存开关 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button Command="{Binding ToggleLoopModeCommand}"
                                    Classes="modeBtn"
                                    Height="28"
                                    MinWidth="90"
                                    CornerRadius="5"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center">
                                <TextBlock Text="{Binding LoopModeText}" FontSize="12" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button Command="{Binding ToggleCacheModeCommand}"
                                    Classes="modeBtn"
                                    Height="28"
                                    MinWidth="90"
                                    CornerRadius="5"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding CacheModeText}" FontSize="12" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <TextBlock Text="🔊" FontSize="12" Foreground="#909090" VerticalAlignment="Center"/>
                            <Slider Minimum="0" Maximum="100" Value="{Binding Volume}" Width="70" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Volume, StringFormat='{}{0}%'}" FontSize="11" Foreground="#a0a0a0" Width="26" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 歌词显示区域 - 固定高度 -->
            <Border DockPanel.Dock="Top"
                    Background="#1e1e1e"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10"
                    Height="100"
                    IsVisible="{Binding HasLyrics}">
                <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="歌词"
                               FontSize="11"
                               Foreground="#606060"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentLyricText}"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#1DB954"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="260"/>
                </StackPanel>
            </Border>

            <!-- 填充剩余空间 -->
            <Border Background="#0a0a0a"/>
        </DockPanel>

        <!-- 第三列：播放列表 -->
        <Border Grid.Column="2" Background="#121212">
            <DockPanel Margin="16,16">
                <!-- 标题 -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="播放列表" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"/>
                        <TextBlock Text="双击播放 · × 移除 · ↻ 更新缓存" Foreground="#606060" FontSize="11"/>
                    </StackPanel>
                    <!-- 缓存设置按钮 -->
                    <Border Grid.Column="1" Width="26" Height="26" Background="#2a2a2a" CornerRadius="4"
                            Tapped="OnCacheSettingsTapped" Cursor="Hand" VerticalAlignment="Top">
                        <Border.Styles>
                            <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="#3a3a3a"/>
                            </Style>
                        </Border.Styles>
                        <TextBlock Text="⚙" FontSize="14" Foreground="#808080" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- 播放列表 -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Playlist}" x:Name="PlaylistCtrl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Panel>
                                    <!-- 正在播放时的样式 -->
                                    <Border Padding="10,6"
                                            Background="#1DB954"
                                            CornerRadius="4"
                                            IsVisible="{Binding IsPlaying}"
                                            DoubleTapped="OnPlaylistItemDoubleTapped">
                                        <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0" Text="♪" FontSize="12" Foreground="Black" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="Black" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                            <!-- 缓存图标 -->
                                            <Border Grid.Column="2" Width="18" Height="18" Background="#000" CornerRadius="9" Margin="4,0" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsCached}">
                                                <TextBlock Text="✓" FontSize="11" Foreground="#1DB954" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- 更新缓存按钮 -->
                                            <Border Grid.Column="3" Width="22" Height="22" Background="Black" CornerRadius="11" Tapped="OnUpdateCacheButtonTapped" Cursor="Hand" Opacity="0.6" Margin="4,0" VerticalAlignment="Center">
                                                <TextBlock Text="↻" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- 删除按钮 -->
                                            <Border Grid.Column="4" Width="22" Height="22" Background="Black" CornerRadius="11" Tapped="OnRemoveButtonTapped" Cursor="Hand" Opacity="0.6" VerticalAlignment="Center">
                                                <TextBlock Text="×" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <!-- 未播放时的样式 -->
                                    <Border Padding="10,6" Background="Transparent" IsVisible="{Binding !IsPlaying}" DoubleTapped="OnPlaylistItemDoubleTapped" CornerRadius="4">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#1a1a1a"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#e0e0e0" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                            <!-- 缓存图标 -->
                                            <Border Grid.Column="1" Width="18" Height="18" Background="#1DB954" CornerRadius="9" Margin="4,0" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsCached}">
                                                <TextBlock Text="✓" FontSize="11" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- 更新缓存按钮 -->
                                            <Border Grid.Column="2" Width="22" Height="22" Background="#404040" CornerRadius="11" Tapped="OnUpdateCacheButtonTapped" Cursor="Hand" Opacity="0.5" Margin="4,0" VerticalAlignment="Center">
                                                <Border.Styles>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="Background" Value="#1DB954"/>
                                                    </Style>
                                                </Border.Styles>
                                                <TextBlock Text="↻" Foreground="#e0e0e0" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- 删除按钮 -->
                                            <Border Grid.Column="3" Width="22" Height="22" Background="#404040" CornerRadius="11" Tapped="OnRemoveButtonTapped" Cursor="Hand" Opacity="0.5" VerticalAlignment="Center">
                                                <Border.Styles>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="Background" Value="#c0392b"/>
                                                    </Style>
                                                </Border.Styles>
                                                <TextBlock Text="×" Foreground="#e0e0e0" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>

    <Window.Styles>
        <!-- 控制按钮样式 -->
        <Style Selector="Button.ctrlBtn">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#d0d0d0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ctrlBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4a4a4a"/>
        </Style>

        <!-- 播放按钮样式 -->
        <Style Selector="Button.playBtn">
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.playBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22e05b"/>
        </Style>

        <!-- 模式按钮样式 -->
        <Style Selector="Button.modeBtn">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="#b0b0b0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.modeBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="BorderBrush" Value="#1DB954"/>
        </Style>
        <Style Selector="Button.modeBtn:pointerover">
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- 音量滑块样式 -->
        <Style Selector="Slider">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="#1DB954"/>
        </Style>
    </Window.Styles>
</Window>